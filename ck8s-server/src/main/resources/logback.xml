<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} [%thread{16}] [%-5level] %logger{24} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="io.fabric8.kubernetes.client.dsl.internal.WatchConnectionManager" level="ERROR" />
    <logger name="com.walmartlabs.concord.agent.executors.runner.ProcessPool" level="WARN" />

    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
